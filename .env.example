# =============================================================================
# GHL Analytics Platform — Variables de Entorno
# Referencia: GHL_Platform.txt sección 4
# Copiar a .env y completar. Las variables marcadas [SECRET] deben configurarse
# en EasyPanel Secret Manager — nunca escribirlas en texto plano en código.
# =============================================================================

# =============================================================================
# SISTEMA / RED
# =============================================================================

# Dominio base del stack (sin https://)
# Ejemplo: sixteam.pro → genera n8n.sixteam.pro, analytics.sixteam.pro, etc.
DOMAIN=tudominio.com

# Email para notificaciones de expiración de certificados Let's Encrypt
LETSENCRYPT_EMAIL=admin@tudominio.com

# =============================================================================
# POSTGRESQL 16
# =============================================================================

# Nombre de la base de datos principal de analytics
POSTGRES_DB=ghl_analytics

# Usuario principal de PostgreSQL (propietario de la BD)
POSTGRES_USER=ghl_user

# [SECRET] Contraseña del usuario principal de PostgreSQL
POSTGRES_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# Puerto interno de PostgreSQL (no exponer al exterior)
POSTGRES_PORT=5432

# Ruta del volumen de datos persistentes
PGDATA=/var/lib/postgresql/data

# =============================================================================
# N8N — ORQUESTADOR ETL
# =============================================================================

# Habilitar autenticación básica en la UI de n8n
N8N_BASIC_AUTH_ACTIVE=true

# Usuario de acceso a la UI de n8n
N8N_BASIC_AUTH_USER=admin

# [SECRET] Contraseña de acceso a la UI de n8n
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# Subdominio público de n8n (sin https://)
N8N_HOST=n8n.tudominio.com

# Puerto interno de n8n
N8N_PORT=5678

# Protocolo — siempre https en producción
N8N_PROTOCOL=https

# URL base completa para webhooks de GHL (incluye slash final)
WEBHOOK_URL=https://n8n.tudominio.com/

# Base de datos interna de n8n (BD SEPARADA de ghl_analytics)
DB_POSTGRESDB_DATABASE=n8n_internal

# Usuario de n8n en PostgreSQL
DB_POSTGRESDB_USER=n8n_user

# [SECRET] Contraseña del usuario n8n en PostgreSQL
DB_POSTGRESDB_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# [SECRET] Clave de encriptación para credenciales almacenadas en n8n
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CAMBIAR_POR_SECRET_MANAGER

# [SECRET] API Key de GHL a nivel Agency (no subaccount)
GHL_API_KEY=CAMBIAR_POR_SECRET_MANAGER

# IDs de subaccounts de GHL a sincronizar (separados por coma)
GHL_LOCATION_IDS=loc_id1,loc_id2,loc_id3

# [SECRET] Secret para validar firma HMAC X-GHL-Signature de webhooks
WEBHOOK_SECRET=CAMBIAR_POR_SECRET_MANAGER

# [SECRET] Token de Meta Cloud API para recibir webhooks CTWA
# Solo requerido si el cliente usa WhatsApp CTWA ads
META_CLOUD_API_TOKEN=CAMBIAR_POR_SECRET_MANAGER

# [SECRET] Token de verificación del webhook de Meta Cloud API
META_VERIFY_TOKEN=CAMBIAR_POR_SECRET_MANAGER

# Guardar ejecuciones fallidas en BD de n8n para debug
EXECUTIONS_DATA_SAVE_ON_ERROR=all

# Retención de historial de ejecuciones en horas (168 = 7 días)
EXECUTIONS_DATA_MAX_AGE=168

# =============================================================================
# METABASE OSS
# =============================================================================

# Nombre de la BD interna de estado de Metabase (SEPARADA de ghl_analytics)
MB_DB_DBNAME=metabase_app

# Usuario de Metabase en PostgreSQL
MB_DB_USER=metabase_user

# [SECRET] Contraseña del usuario de Metabase en PostgreSQL
MB_DB_PASS=CAMBIAR_POR_SECRET_MANAGER

# URL pública de Metabase (incluye https://)
MB_SITE_URL=https://analytics.tudominio.com

# [SECRET] Clave para firmar tokens JWT de embeddings de Metabase
# Generar con: openssl rand -hex 32
# Solo requerido si se usan embeddings en portales de cliente
MB_EMBEDDING_SECRET_KEY=CAMBIAR_POR_SECRET_MANAGER

# Timezone — crítico para correcta visualización de fechas en reportes
JAVA_TIMEZONE=America/Bogota

# Deshabilitar email de bienvenida al primer login (recomendado en prod)
MB_SEND_EMAIL_ON_FIRST_LOGIN=false

# =============================================================================
# INTELIGENCIA ARTIFICIAL — WF-AI_enricher (opcional)
# =============================================================================

# URL del endpoint de embeddings
# Default: OpenAI text-embedding-ada-002. Puede apuntar a un modelo local.
AI_EMBEDDING_URL=https://api.openai.com/v1/embeddings

# Modelo de embeddings a usar (debe producir vectores de 1536 dims para pgvector)
AI_EMBEDDING_MODEL=text-embedding-ada-002

# URL del LLM para clasificación de intent y sentiment por mensaje
# Default: OpenAI. Puede apuntar a LM Studio, Ollama, etc.
AI_LLM_URL=https://api.openai.com/v1/chat/completions

# Modelo LLM para intent/sentiment
AI_LLM_MODEL=gpt-4o-mini

# [SECRET] API Key de OpenAI (requerida si se usan endpoints de OpenAI)
OPENAI_API_KEY=CAMBIAR_POR_SECRET_MANAGER

# =============================================================================
# META ADS — WF-11 CTWA Enricher + Meta CAPI
# =============================================================================

# ID del Pixel de Meta para enviar conversion events via Meta Conversions API
# Requerido para WF-11 cuando una oportunidad CTWA llega a estado 'won'
META_PIXEL_ID=

# =============================================================================
# UPTIME KUMA — WF-12 Health Check Reporter
# =============================================================================

# URL push de Uptime Kuma para reportar estado de salud (push monitor)
# Obtener en Uptime Kuma → Add New Monitor → Push
UPTIME_KUMA_PUSH_URL=https://uptime.tudominio.com/api/push/xxxxxxxxxxxx

# =============================================================================
# TESTS — Variables para la suite de QA (tests/run_all.sh)
# NO configurar en producción — solo en entorno de pruebas
# =============================================================================

# Credenciales de Metabase admin para tests
METABASE_ADMIN_USER=admin@sixteam.pro
METABASE_ADMIN_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# Credenciales de usuario cliente de prueba en Metabase
METABASE_CLIENT_USER=cliente@ejemplo.com
METABASE_CLIENT_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# location_id del cliente A (para tests de ingestión y RLS)
CLIENT_LOCATION_ID=loc_test_a

# location_id de un SEGUNDO cliente B (para verificar aislamiento RLS)
OTHER_LOCATION_ID=loc_test_b

# Nombre del rol PostgreSQL del cliente A
CLIENT_A_ROLE=client_loc_test_a
CLIENT_A_PASSWORD=CAMBIAR_POR_SECRET_MANAGER

# location_id del cliente B (distintor de A — verifica que A no ve datos de B)
CLIENT_B_LOCATION_ID=loc_test_b

# location_id genérico para datos seed de tests ETL
TEST_LOCATION_ID=loc_test_etl

# Directorio de backups (para test INFRA-05)
BACKUP_DIR=/var/backups/postgres

# Mínimo de location_ids distintos que debe ver sixteam_admin (para SEC-02)
MIN_LOCATIONS=2
