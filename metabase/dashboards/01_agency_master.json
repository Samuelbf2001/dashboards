{
  "name": "Agency Master",
  "description": "Dashboard maestro multi-cliente. Vista consolidada de todos los clientes de Sixteam con filtro opcional por location_id. Consume mv_unified_attribution como fuente principal.",
  "parameters": [
    {
      "name": "Location",
      "slug": "location_id",
      "type": "category",
      "required": false,
      "default": null
    },
    {
      "name": "Fecha inicio",
      "slug": "date_from",
      "type": "date/single",
      "required": false
    },
    {
      "name": "Fecha fin",
      "slug": "date_to",
      "type": "date/single",
      "required": false
    }
  ],
  "cards": [
    {
      "name": "Total contactos activos",
      "visualization": "scalar",
      "query_file": "queries/01_agency_total_contacts.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Oportunidades abiertas",
      "visualization": "scalar",
      "query_file": "queries/01_agency_open_opps.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id"]
    },
    {
      "name": "Revenue ganado",
      "visualization": "scalar",
      "query_file": "queries/01_agency_revenue_won.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Tasa de conversion global",
      "visualization": "scalar",
      "query_file": "queries/01_agency_conversion_rate.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Contactos por cliente",
      "visualization": "bar",
      "query_file": "queries/01_agency_contacts_by_location.sql",
      "size": { "width": 12, "height": 6 },
      "filters": ["date_from", "date_to"]
    },
    {
      "name": "Top 5 fuentes UTM",
      "visualization": "bar",
      "query_file": "queries/01_agency_top_utm_sources.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Top 5 campanas CTWA",
      "visualization": "bar",
      "query_file": "queries/01_agency_top_ctwa_campaigns.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Revenue por cliente",
      "visualization": "bar",
      "query_file": "queries/01_agency_revenue_by_location.sql",
      "size": { "width": 12, "height": 6 },
      "filters": ["date_from", "date_to"]
    }
  ]
}
