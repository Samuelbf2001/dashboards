{
  "name": "Citas",
  "description": "Tasa show/no-show, citas por asesor, ratio agenda a cierre y no-show rate por canal de origen de la conversacion.",
  "parameters": [
    {
      "name": "Location",
      "slug": "location_id",
      "type": "category",
      "required": false,
      "default": null
    },
    {
      "name": "Fecha inicio",
      "slug": "date_from",
      "type": "date/single",
      "required": false
    },
    {
      "name": "Fecha fin",
      "slug": "date_to",
      "type": "date/single",
      "required": false
    }
  ],
  "cards": [
    {
      "name": "Total citas agendadas",
      "visualization": "scalar",
      "query_file": "queries/06_appt_total.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Tasa show (asistieron / agendadas)",
      "visualization": "scalar",
      "query_file": "queries/06_appt_show_rate.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Tasa no-show",
      "visualization": "scalar",
      "query_file": "queries/06_appt_noshow_rate.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Citas por asesor",
      "visualization": "bar",
      "query_file": "queries/06_appt_by_assignee.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "No-show rate por asesor",
      "visualization": "bar",
      "query_file": "queries/06_appt_noshow_by_assignee.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "No-show rate por canal de origen",
      "visualization": "bar",
      "query_file": "queries/06_appt_noshow_by_channel.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Ratio agenda a cierre de oportunidad",
      "visualization": "scalar",
      "query_file": "queries/06_appt_agenda_to_close_ratio.sql",
      "size": { "width": 6, "height": 3 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Citas por dia",
      "visualization": "line",
      "query_file": "queries/06_appt_by_day.sql",
      "size": { "width": 12, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    }
  ]
}
