{
  "name": "Conversaciones",
  "description": "Avg first reply time por inbox/canal/asesor, distribucion por canal, conversaciones abiertas vs cerradas, top inbound intents y ratio sentimiento negativo por asesor.",
  "parameters": [
    {
      "name": "Location",
      "slug": "location_id",
      "type": "category",
      "required": false,
      "default": null
    },
    {
      "name": "Fecha inicio",
      "slug": "date_from",
      "type": "date/single",
      "required": false
    },
    {
      "name": "Fecha fin",
      "slug": "date_to",
      "type": "date/single",
      "required": false
    },
    {
      "name": "Canal",
      "slug": "channel_type",
      "type": "category",
      "required": false
    }
  ],
  "cards": [
    {
      "name": "Avg First Reply Time (segundos)",
      "visualization": "scalar",
      "query_file": "queries/04_conv_avg_first_reply.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id", "date_from", "date_to", "channel_type"]
    },
    {
      "name": "Conversaciones abiertas",
      "visualization": "scalar",
      "query_file": "queries/04_conv_open_count.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id"]
    },
    {
      "name": "Conversaciones cerradas hoy",
      "visualization": "scalar",
      "query_file": "queries/04_conv_closed_today.sql",
      "size": { "width": 4, "height": 3 },
      "filters": ["location_id"]
    },
    {
      "name": "Avg First Reply por canal",
      "visualization": "bar",
      "query_file": "queries/04_conv_reply_by_channel.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Avg First Reply por asesor",
      "visualization": "bar",
      "query_file": "queries/04_conv_reply_by_assignee.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Distribucion por canal",
      "visualization": "pie",
      "query_file": "queries/04_conv_by_channel.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Abiertas vs Cerradas por canal",
      "visualization": "bar",
      "query_file": "queries/04_conv_open_vs_closed.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Top inbound intents",
      "visualization": "bar",
      "query_file": "queries/04_conv_top_intents.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    },
    {
      "name": "Ratio sentimiento negativo por asesor",
      "visualization": "table",
      "query_file": "queries/04_conv_negative_sentiment_by_assignee.sql",
      "size": { "width": 6, "height": 6 },
      "filters": ["location_id", "date_from", "date_to"]
    }
  ]
}
