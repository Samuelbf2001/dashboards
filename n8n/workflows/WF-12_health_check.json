{
  "name": "WF-12 Health Check Reporter",
  "nodes": [
    {
      "id": "node-01-cron",
      "name": "Cron cada 15 min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300],
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 15 }]
        }
      }
    },
    {
      "id": "node-02-ping-postgres",
      "name": "Ping PostgreSQL",
      "type": "n8n-nodes-base.postgres",
      "position": [460, 200],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT 1 AS ok"
      },
      "credentials": {
        "postgres": { "id": "postgres-n8n-writer", "name": "Postgres n8n_writer" }
      },
      "continueOnFail": true
    },
    {
      "id": "node-03-ping-n8n",
      "name": "Ping n8n Healthz",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 340],
      "parameters": {
        "method": "GET",
        "url": "http://localhost:5678/healthz",
        "options": { "timeout": 5000 }
      },
      "continueOnFail": true
    },
    {
      "id": "node-04-ping-metabase",
      "name": "Ping Metabase Health",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 480],
      "parameters": {
        "method": "GET",
        "url": "={{ 'http://metabase:3000/api/health' }}",
        "options": { "timeout": 5000 }
      },
      "continueOnFail": true
    },
    {
      "id": "node-05-aggregate",
      "name": "Agregar Resultados",
      "type": "n8n-nodes-base.code",
      "position": [700, 340],
      "parameters": {
        "jsCode": "// Recolectar resultados de los 3 pings\nconst pgResult       = $('Ping PostgreSQL').first().json;\nconst n8nResult      = $('Ping n8n Healthz').first().json;\nconst metabaseResult = $('Ping Metabase Health').first().json;\n\nconst now = new Date().toISOString();\n\nconst checks = {\n  postgres: {\n    status:    pgResult && pgResult.ok === 1 ? 'up' : 'down',\n    checked_at: now\n  },\n  n8n: {\n    status:    n8nResult && !n8nResult.error ? 'up' : 'down',\n    checked_at: now\n  },\n  metabase: {\n    status:    metabaseResult && metabaseResult.status === 'ok' ? 'up' : 'down',\n    checked_at: now\n  }\n};\n\nconst allUp = Object.values(checks).every(c => c.status === 'up');\n\nreturn [{ json: { checks, allUp, timestamp: now } }];"
      }
    },
    {
      "id": "node-06-report-kuma",
      "name": "Reportar a Uptime Kuma",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 340],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.UPTIME_KUMA_PUSH_URL || 'http://uptime-kuma:3001/api/push/placeholder' }}",
        "queryParameters": {
          "parameters": [
            { "name": "status", "value": "={{ $json.allUp ? 'up' : 'down' }}" },
            { "name": "msg",    "value": "={{ JSON.stringify($json.checks) }}" },
            { "name": "ping",   "value": "1" }
          ]
        },
        "options": { "timeout": 5000 }
      },
      "continueOnFail": true
    },
    {
      "id": "node-07-alert",
      "name": "Servicio Caido?",
      "type": "n8n-nodes-base.if",
      "position": [1140, 340],
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.allUp }}", "value2": false }]
        }
      }
    },
    {
      "id": "node-08-log",
      "name": "Registrar Falla en Postgres",
      "type": "n8n-nodes-base.postgres",
      "position": [1360, 260],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE ghl_sync_state SET last_error = $1, updated_at = NOW() WHERE entity = 'system_health' AND location_id = 'global'",
        "additionalFields": {
          "queryParams": "={{ [ JSON.stringify($json.checks) ] }}"
        }
      },
      "credentials": {
        "postgres": { "id": "postgres-n8n-writer", "name": "Postgres n8n_writer" }
      },
      "continueOnFail": true
    }
  ],
  "connections": {
    "Cron cada 15 min": {
      "main": [
        [
          { "node": "Ping PostgreSQL",     "type": "main", "index": 0 },
          { "node": "Ping n8n Healthz",    "type": "main", "index": 0 },
          { "node": "Ping Metabase Health","type": "main", "index": 0 }
        ]
      ]
    },
    "Ping PostgreSQL":     { "main": [[{ "node": "Agregar Resultados", "type": "main", "index": 0 }]] },
    "Ping n8n Healthz":    { "main": [[{ "node": "Agregar Resultados", "type": "main", "index": 0 }]] },
    "Ping Metabase Health":{ "main": [[{ "node": "Agregar Resultados", "type": "main", "index": 0 }]] },
    "Agregar Resultados":   { "main": [[{ "node": "Reportar a Uptime Kuma", "type": "main", "index": 0 }]] },
    "Reportar a Uptime Kuma": { "main": [[{ "node": "Servicio Caido?", "type": "main", "index": 0 }]] },
    "Servicio Caido?": {
      "main": [
        [{ "node": "Registrar Falla en Postgres", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataSuccessExecution": "none",
    "saveManualExecutions": false
  }
}
