              {
                "id": "dcc12350-4f42-4024-8e43-2d0dbb39c398",
                "name": "plantilla_html",
                "type": "string",
                "value": "=<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <title>Comprobante de pago - Evolucione</title>\n  <style>\n    body{margin:0;padding:0;background:#f2f6fb;font-family:Arial,Helvetica,sans-serif}\n    img{display:block;border:0;outline:0;text-decoration:none;max-width:100%}\n    table{border-collapse:collapse;mso-table-lspace:0pt;mso-table-rspace:0pt}\n    .main{max-width:550px;margin:0 auto}\n  </style>\n</head>\n<body>\n  <center role=\"article\" aria-roledescription=\"email\" style=\"width:100%;background:#f2f6fb;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" class=\"main\">\n\n      <!-- Banner superior -->\n      <tr>\n        <td>\n          <img src=\"https://49611461.fs1.hubspotusercontent-na1.net/hubfs/49611461/Evo_ReciboPago_02.png\"\n               alt=\"Evolucione\"\n               style=\"width:100%;height:auto;border-top-left-radius:14px;border-top-right-radius:14px;\">\n        </td>\n      </tr>\n\n      <!-- Intro -->\n      <tr>\n        <td style=\"background:#ffffff;padding:18px 18px 10px;text-align:center;\">\n          <p style=\"margin:0 0 5px;font-size:21px;line-height:1.3;color:#0b6ea9;font-weight:700;\">\n            Hola {{ $json.nombre }}, ¡Gracias por tu pago!\n          </p>\n          <p style=\"margin:0 0 8px;font-size:15px;color:#5f6f7f;\">\n            A continuación te compartimos los detalles:\n          </p>\n        </td>\n      </tr>\n\n      <!-- Tarjeta: contenedor azul con tarjeta blanca -->\n      <tr>\n        <td style=\"background:#ffffff;padding:0 18px;\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\n                 style=\"background:#eaf3ff;border-radius:16px;\">\n            <tr>\n              <td style=\"padding:9px;\">\n                <table role=\"presentation\" width=\"100%\" cellpadding=\"6\" cellspacing=\"0\" border=\"0\"\n                       style=\"background:#ffffff;border-radius:16px;\">\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#ffffff;\">\n                      Folio de la cuota:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#ffffff;\">\n                      {{ $json['folio de cuota'] }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#e8f1fb;\">\n                      Nombre completo:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#e8f1fb;\">\n                      {{ $json.nombre }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#ffffff;\">\n                      Matrícula:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#ffffff;\">\n                      {{ $json.contrato }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#e8f1fb;\">\n                      Importe pagado:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#e8f1fb;\">\n                      {{ $json['saldo pagado'] }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#ffffff;\">\n                      Saldo anterior:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#ffffff;\">\n                      {{ $json['saldo anterior'] }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#e8f1fb;\">\n                      Saldo actual:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#e8f1fb;\">\n                      {{ $json['saldo actual'] }}\n                    </td>\n                  </tr>\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#ffffff;\">\n                      Forma de pago:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#ffffff;\">\n                      {{ $json['Forma de pago'] }}\n                    </td>\n                  </tr>\n                  <!-- Última fila con bordes inferiores redondeados -->\n                  <tr>\n                    <td style=\"padding:12px 16px;font-size:15px;color:#657a91;background:#e8f1fb;border-bottom-left-radius:14px;\">\n                      Fecha de pago:\n                    </td>\n                    <td align=\"right\" style=\"padding:12px 16px;font-size:15px;color:#2f4560;background:#e8f1fb;border-bottom-right-radius:14px;\">\n                      {{ $json['fecha de pago'] }}\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n\n      <!-- ESPACIO EN BLANCO ENTRE TARJETA Y BANNER -->\n      <tr>\n        <td style=\"background:#ffffff;height:16px;line-height:16px;font-size:0;\">&nbsp;</td>\n      </tr>\n\n      <!-- Pie con imagen -->\n      <tr>\n        <td>\n          <img src=\"https://49611461.fs1.hubspotusercontent-na1.net/hubfs/49611461/Evo_ReciboPago_03.png\"\n               alt=\"Redes Evolucione\"\n               style=\"width:100%;height:auto;border-bottom-left-radius:14px;border-bottom-right-radius:14px;\">\n        </td>\n      </tr>\n\n    </table>\n  </center>\n</body>\n</html>\n"
              }
            ]
