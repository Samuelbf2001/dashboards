        ],
        "parameters": {
          "jsCode": "// Toma todos los items de entrada\nconst items = $input.all();\n\nfunction get(obj, path) {\n  return String(path).split('.').reduce((o, k) => (o && o[k] != null ? o[k] : ''), obj);\n}\n\nfor (const item of items) {\n  const ctx = item.json || {};\n  const tpl = ctx.plantilla_html;\n\n  if (typeof tpl !== 'string') {\n    // Mensaje claro si falta la plantilla\n    throw new Error(\"Falta 'plantilla_html' en item.json (debe ser String con el HTML de la plantilla).\");\n  }\n\n  // Render {{variable}} o {{obj.campo}}\n  const html = tpl.replace(/{{\\s*([\\w.]+)\\s*}}/g, (_, key) => {\n    const val = get(ctx, key);\n    return val == null ? '' : String(val);\n  });\n\n  // Crear binario para HTTP Request (Gotenberg)\n  item.binary = item.binary || {};\n  item.binary.data = {\n    data: Buffer.from(html, 'utf8'),\n    fileName: 'index.html',\n    mimeType: 'text/html',\n  };\n}\n\nreturn items;\n"
        },
        "typeVersion": 2
      },
