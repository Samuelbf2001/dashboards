        "parameters": {
          "jsCode": "const saldo_pagado = $input.first().json.body.saldo_pagado;\nconst saldo_anterior = $input.first().json.body.saldo_anterior;\nconst saldo_actual  = $input.first().json.body.Saldo_actual;\n\n// Formateador para moneda en formato colombiano\nconst formatoCOP = new Intl.NumberFormat(\"es-CO\", {\n  style: \"currency\",\n  currency: \"COP\",\n  minimumFractionDigits: 2\n});\n\nreturn [\n  {\n    json: {\n      saldo_pagado: formatoCOP.format(saldo_pagado),\n      saldo_anterior: formatoCOP.format(saldo_anterior),\n      saldo_actual: formatoCOP.format(saldo_actual)\n    }\n  }\n];\n\n"
        },
